@model EXAMENUNI3.Models.Proyecto
@{
    ViewData["Title"] = "Detalles del Proyecto";
}

<h1>@Model.Nombre</h1>
<div class="card mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.Nombre</dd>
            <dt class="col-sm-3">Descripción</dt>
            <dd class="col-sm-9">@Model.Descripcion</dd>
            <dt class="col-sm-3">Fecha de Inicio</dt>
            <dd class="col-sm-9">@Model.FechaInicio.ToShortDateString()</dd>
            <dt class="col-sm-3">Fecha de Finalización</dt>
            <dd class="col-sm-9">@Model.FechaFinalizacion?.ToShortDateString()</dd>
        </dl>
    </div>
</div>

<h3>Tareas del Proyecto</h3>
@if (Model.Tareas.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Título</th>
                <th>Estado</th>
                <th>Vencimiento</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tarea in Model.Tareas)
            {
                <tr>
                    <td>@tarea.Titulo</td>
                    <td>
                        <span
                            class="badge @(tarea.Estado == "Completada" ? "bg-success" : tarea.Estado == "En progreso" ? "bg-warning" : "bg-secondary")">
                            @tarea.Estado
                        </span>
                    </td>
                    <td>@tarea.FechaVencimiento?.ToShortDateString()</td>
                    <td><a asp-controller="Tareas" asp-action="Details" asp-route-id="@tarea.Id"
                               class="btn btn-sm btn-info">Ver</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
else
    {
        <div class="alert alert-info">No hay tareas para este proyecto.</div>
    }

    <a asp-controller="Tareas" asp-action="Create" asp-route-proyectoId="@Model.Id" class="btn btn-success">+ Agregar
        Tarea</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
